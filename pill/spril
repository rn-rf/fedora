#!/usr/bin/env bash

PID_FILE="/tmp/spril.pid"

# Kill previous instance properly
if [ -f "$PID_FILE" ]; then
    OLD_PID=$(cat "$PID_FILE")

    if kill -0 "$OLD_PID" 2>/dev/null; then
        kill "$OLD_PID"

        # 🔥 WAIT until it's actually dead
        while kill -0 "$OLD_PID" 2>/dev/null; do
            sleep 0.05
        done
    fi

    rm -f "$PID_FILE"
    makoctl dismiss -a statusbar
fi

# Save current PID
echo $$ > "$PID_FILE"
trap 'rm -f "$PID_FILE"' EXIT

# ===== INPUT =====
TEXT="$1"

MAX_LEN=35
DELAY=0.5
ID=999

[[ -z "$TEXT" ]] && exit 1

# ===== NORMAL =====
if [[ ${#TEXT} -le $MAX_LEN ]]; then
    notify-send -a statusbar -r $ID \
        -h string:x-canonical-private-synchronous:statusbar \
        "$TEXT"

    debounce 0.1
    exit 0
fi

# ===== SCROLL =====
TEXT="$TEXT     "
LEN=${#TEXT}

for ((i=0; i<=LEN-MAX_LEN; i++)); do
    PART="${TEXT:$i:$MAX_LEN}"

    notify-send -a statusbar -r $ID \
        -h string:x-canonical-private-synchronous:statusbar \
        "$PART"

    sleep "$DELAY"
done

debounce 0.1
