#!/usr/bin/env bash

# ===== CONFIG =====

DELAY="${1:-2}"   # default delay = 2 sec
TEXT_INPUT="$2"   # optional custom text
PID_FILE="/tmp/debounce_script.pid"

# Validate delay (fallback if invalid)
if ! [[ "$DELAY" =~ ^[0-9]+$ ]]; then
    DELAY=2
fi

# ===== YOUR FINAL ACTION =====

end_script() {
    pill
}

# ===== LOGIC =====

# Kill previous timer if exists
if [ -f "$PID_FILE" ]; then
    OLD_PID=$(cat "$PID_FILE")
    kill "$OLD_PID" 2>/dev/null
fi

# Start new delayed execution
(
    sleep "$DELAY"
    end_script
    rm -f "$PID_FILE"
) &

# Save new PID
echo $! > "$PID_FILE"
